# 部署 H5 预览站（如 *.hoardly-demo.app）时可选：写入已安装的扩展 ID，页面会自动尝试拉取真实 Chrome 书签
# VITE_HOARDLY_EXTENSION_ID=abcdefghijklmnopqrstuvwxyz123456

# Recommended setup for local preview:
HOARDLY_AI_PROVIDER=openrouter
VITE_HOARDLY_AI_PROVIDER=openrouter
VITE_HOARDLY_AI_MODEL=inclusionai/ling-2.6-flash
OPENROUTER_API_KEY=

# Optional: expose a browser-side key only for temporary debugging.
# The local Vite proxy above is safer for preview because it keeps the key server-side.
# VITE_OPENROUTER_API_KEY=

# Strict bookmark tagging method 2. Configure at least one of these, or fill it in the extension Settings.
# VITE_FIRECRAWL_API_KEY=
# VITE_FIRECRAWL_API_URL=https://api.firecrawl.dev/v2/scrape
# VITE_CRAWL4AI_ENDPOINT=

# Optional Groq free setup:
# HOARDLY_AI_PROVIDER=groq
# VITE_HOARDLY_AI_PROVIDER=groq
# VITE_HOARDLY_AI_MODEL=llama-3.1-8b-instant
# GROQ_API_KEY=
# VITE_GROQ_API_KEY=

# Optional DeepSeek setup:
# HOARDLY_AI_PROVIDER=deepseek
# VITE_HOARDLY_AI_PROVIDER=deepseek
# VITE_HOARDLY_AI_MODEL=deepseek-v4-flash
# DEEPSEEK_API_KEY=

# Optional OpenAI-compatible setup:
# HOARDLY_AI_PROVIDER=openai
# VITE_HOARDLY_AI_PROVIDER=openai
# VITE_HOARDLY_AI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=

# Optional custom OpenAI-compatible endpoint:
# HOARDLY_AI_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
